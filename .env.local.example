# 백엔드 API 베이스 URL
# - 도메인: promate.ai.kr
# - API: api.promate.ai.kr
# - 로그인 유저 정보: GET /api/users/me
# - 내 프로젝트 목록: GET /api/projects/me
# - 팀원 목록: GET /api/projects/{projectId}/members
# - 프로젝트 생성: POST /api/projects
# - 프로젝트 참여: POST /api/projects/join
# - 채팅 내역 조회: GET /api/chat/{projectId}/messages
# - 노션 내보내기: POST /api/projects/{projectId}/export
# - AI 템플릿 생성: POST /ai/project/templates
NEXT_PUBLIC_API_BASE_URL=https://api.promate.ai.kr

# WebSocket STOMP URL (선택, 기본: {API_BASE_URL}/ws-stomp)
# NEXT_PUBLIC_WS_STOMP_URL=https://api.promate.ai.kr/ws-stomp
